    {
      "name": "GET Pokemon Valido (Mewtwo)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar conexión\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Validar tipos de datos y valores exactos\r",
              "pm.test(\"El JSON tiene la estructura correcta para Mewtwo\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    // Verificamos que 'id' es número y es el 150\r",
              "    pm.expect(jsonData.id).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.id).to.eql(150);\r",
              "    \r",
              "    // Verificamos que 'name' es texto y tiene la M mayúscula\r",
              "    pm.expect(jsonData.name).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.name).to.eql(\"Mewtwo\");\r",
              "});\r",
              "\r",
              "// 3. Validar los detalles internos\r",
              "pm.test(\"Contiene sus stats y tipo psíquico\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    // Mewtwo es tipo psíquico (psychic)\r",
              "    pm.expect(jsonData.types).to.be.an(\"array\").that.includes(\"psychic\");\r",
              "    \r",
              "    // Nos aseguramos de que el campo sprite existe\r",
              "    pm.expect(jsonData).to.have.property(\"sprite\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
