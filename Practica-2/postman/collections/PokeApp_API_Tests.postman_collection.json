  "item": [
    {
      "name": "GET Pokemon Valido (Pikachu)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar que la conexión ha sido un éxito (Código HTTP 200)\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Validar que la API es rápida\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// 3. Validar los datos básicos (Corregido con mayúscula)\r",
              "pm.test(\"El JSON devuelve a Pikachu correctamente\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.id).to.eql(25);\r",
              "    // ¡Aquí está la corrección! Esperamos \"Pikachu\" con P mayúscula\r",
              "    pm.expect(jsonData.name).to.eql(\"Pikachu\"); \r",
              "    pm.expect(jsonData.sprite).to.include(\"http\");\r",
              "});\r",
              "\r",
              "// 4. EXTRA: Validar la estructura compleja (Stats y Tipos)\r",
              "pm.test(\"Contiene los stats y el tipo eléctrico\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    // Validamos que 'types' es una lista y contiene \"electric\"\r",
              "    pm.expect(jsonData.types).to.be.an(\"array\").that.includes(\"electric\");\r",
              "    \r",
              "    // Validamos que existe el objeto 'stats' y su velocidad es 90\r",
              "    pm.expect(jsonData.stats).to.be.an(\"object\");\r",
              "    pm.expect(jsonData.stats).to.have.property(\"hp\");\r",
              "    pm.expect(jsonData.stats.speed).to.eql(90);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
